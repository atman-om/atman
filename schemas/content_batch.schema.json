{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AtmanContentBatch",
  "type": "object",
  "required": [
    "name",
    "content_type",
    "topic",
    "quantity"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "content_type": {
      "enum": [
        "notes",
        "qa",
        "mcq",
        "flashcards",
        "explainer",
        "lesson_plan",
        "article",
        "daily_wisdom",
        "worksheet",
        "shorts_script",
        "social_post"
      ]
    },
    "topic": {
      "type": "string"
    },
    "language": {
      "type": "string",
      "default": "hi"
    },
    "difficulty": {
      "enum": [
        "basic",
        "intermediate",
        "advanced"
      ]
    },
    "quantity": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5000
    },
    "source_required": {
      "type": "boolean",
      "default": true
    }
  }
}
