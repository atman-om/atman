{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CanonicalPassage",
  "type": "object",
  "required": [
    "work_key",
    "locator",
    "normalized_text"
  ],
  "properties": {
    "work_key": {
      "type": "string"
    },
    "locator": {
      "type": "string"
    },
    "sanskrit_text": {
      "type": [
        "string",
        "null"
      ]
    },
    "normalized_text": {
      "type": "string"
    },
    "translation_hi": {
      "type": [
        "string",
        "null"
      ]
    },
    "translation_en": {
      "type": [
        "string",
        "null"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "review_status": {
      "type": "string"
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}