ATMAN_ENV=local
ATMAN_LOG_LEVEL=INFO
ATMAN_API_HOST=0.0.0.0
ATMAN_API_PORT=8000
ATMAN_DATABASE_URL=postgresql+asyncpg://atman:atman@postgres:5432/atman
ATMAN_SYNC_DATABASE_URL=postgresql+psycopg://atman:atman@postgres:5432/atman
ATMAN_REDIS_URL=redis://redis:6379/0
ATMAN_QDRANT_URL=http://qdrant:6333
ATMAN_QDRANT_COLLECTION=atman_chunks
ATMAN_OBJECT_STORE_ENDPOINT=http://minio:9000
ATMAN_OBJECT_STORE_BUCKET=atman-corpus
ATMAN_OBJECT_STORE_ACCESS_KEY=atman
ATMAN_OBJECT_STORE_SECRET_KEY=atman-secret
ATMAN_JWT_SECRET=change-me-in-production
ATMAN_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

ATMAN_MODEL_FAMILY=Qwen
ATMAN_RUNTIME_MODEL=Atman-Lab-Qwen-14B-v1.0
ATMAN_CONTENT_MODEL=Atman-Lab-Qwen-14B-v1.0
ATMAN_EMBEDDING_MODEL=Atman-RAG-QwenEmbedding-v1.0
ATMAN_RERANKER_MODEL=Atman-RAG-QwenReranker-v1.0
ATMAN_EMBEDDING_DIM=384

# deterministic = no model download, offline-safe local fallback
# openai_compatible = vLLM/Ollama/LM Studio/TGI server with /v1/chat/completions
# transformers = optional Hugging Face local runtime; disabled until explicitly enabled
ATMAN_QWEN_RUNTIME_MODE=deterministic
ATMAN_QWEN_MODEL_ID=Qwen/Qwen3-14B
ATMAN_QWEN_SMALL_MODEL_ID=Qwen/Qwen3-4B
ATMAN_QWEN_BASE_URL=
ATMAN_QWEN_API_KEY=
ATMAN_QWEN_TEMPERATURE=0.2
ATMAN_QWEN_MAX_TOKENS=900
ATMAN_QWEN_REQUEST_TIMEOUT_SECONDS=60
ATMAN_QWEN_ENABLE_TRANSFORMERS_RUNTIME=false

# Legacy aliases retained for v0.4-compatible scripts.
ATMAN_LLM_BASE_URL=
ATMAN_LLM_API_KEY=

ATMAN_ENABLE_NETWORK_CRAWL=false
ATMAN_CONTENT_EXPORT_DIR=./generated/exports
ATMAN_CONTENT_MAX_BATCH_ITEMS=250
ATMAN_CONTENT_MIN_SOURCE_COVERAGE=0.60
ATMAN_PUBLIC_APP_NAME=Atman
ATMAN_PUBLIC_DEFAULT_LANGUAGE=hi
ATMAN_PUBLIC_ENABLE_STREAMING=true

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# v0.6 corpus ingestion and review controls
ATMAN_UPLOAD_DIR=./generated/uploads
ATMAN_MAX_UPLOAD_BYTES=25000000
ATMAN_ENABLE_PDF_EXTRACTION=true
ATMAN_ENABLE_OCR_PLACEHOLDER=true
ATMAN_CORPUS_DEFAULT_RIGHTS_STATUS=UNKNOWN
ATMAN_CORPUS_REQUIRE_RIGHTS_FOR_Z2=true

# v0.7 eval hardening and source explorer controls
ATMAN_EVAL_DEFAULT_BENCHMARK=nyayabench_hardened
ATMAN_EVAL_APPROVAL_THRESHOLD=0.92
ATMAN_EVAL_MIN_CITATION_ALIGNMENT=0.95
ATMAN_EVAL_FAKE_SHLOKA_MAX_FAILURES=0
ATMAN_EVAL_SOURCE_REQUIRED_FOR_PUBLIC_ANSWERS=true
ATMAN_SOURCE_EXPLORER_PUBLIC_LIMIT=50

# v0.8 web-to-corpus and OCR controls
ATMAN_CRAWLER_USER_AGENT=AtmanBot/1.0 (+source-governed-corpus; contact=admin@atman.local)
ATMAN_CRAWLER_MAX_BYTES=5000000
ATMAN_CRAWLER_TIMEOUT_SECONDS=20
ATMAN_CRAWLER_REQUIRE_RIGHTS_FOR_FETCH=true
ATMAN_WEB_QUALITY_MIN_SCORE=0.65
ATMAN_OCR_MODE=deterministic
ATMAN_OCR_MIN_CONFIDENCE=0.80
ATMAN_OCR_OUTPUT_DIR=./generated/ocr

# v0.9 Qwen training and ModelOps controls
ATMAN_TRAINING_ARTIFACT_DIR=./generated/training
ATMAN_TRAINING_ALLOW_REAL_JOBS=false
ATMAN_TRAINING_DEFAULT_BASE_MODEL=Qwen/Qwen3-14B
ATMAN_TRAINING_DEFAULT_ADAPTER_METHOD=qlora
ATMAN_TRAINING_LORA_RANK=64
ATMAN_TRAINING_LORA_ALPHA=128
ATMAN_TRAINING_LEARNING_RATE=0.00002
ATMAN_TRAINING_EPOCHS=3
ATMAN_TRAINING_MIN_SAMPLES_FOR_REAL_RUN=500
ATMAN_MODEL_RELEASE_MIN_EVAL_SCORE=0.92
ATMAN_MODEL_RELEASE_REQUIRE_NO_HARD_FAILURES=true

# v1.0 production controls
ATMAN_PRODUCTION_MODE=false
ATMAN_PRODUCTION_REQUIRE_AUTH=false
ATMAN_PRODUCTION_RATE_LIMIT_PER_MINUTE=60
ATMAN_BACKUP_DIR=./generated/backups
ATMAN_READINESS_REQUIRE_QWEN_WHEN_PRODUCTION=false
